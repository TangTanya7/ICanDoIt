generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String   @default("")
  avatarUrl String?
  createdAt DateTime @default(now())

  goals Goal[]
  tasks DailyTask[]

  @@map("icandoit_user")
}

model Goal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  category      String
  icon          String
  startDate     String
  endDate       String
  totalDays     Int
  completedDays Int      @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  color         String
  description   String?  @db.Text
  dailyMinutes  Int
  status        String   @default("active")
  createdAt     DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id])
  phases    GoalPhase[]
  resources GoalResource[]
  tasks     DailyTask[]

  @@index([userId])
  @@map("icandoit_goal")
}

model GoalPhase {
  id             String @id @default(cuid())
  goalId         String
  phaseNumber    Int
  title          String
  description    String @db.Text
  skills         String @db.Text
  startDay       Int
  endDay         Int
  totalTasks     Int    @default(0)
  completedTasks Int    @default(0)
  status         String @default("upcoming")

  goal Goal @relation(fields: [goalId], references: [id])

  @@index([goalId])
  @@map("icandoit_goal_phase")
}

model GoalResource {
  id     String @id @default(cuid())
  goalId String
  url    String @db.Text
  title  String
  type   String @default("url")

  goal Goal @relation(fields: [goalId], references: [id])

  @@index([goalId])
  @@map("icandoit_goal_resource")
}

model DailyTask {
  id               String  @id @default(cuid())
  userId           String
  goalId           String
  goalTitle        String
  title            String
  description      String  @db.Text
  date             String
  status           String  @default("pending")
  color            String
  icon             String
  resourceUrl      String? @db.Text
  resourceTitle    String?
  resourcePlatform String?
  estimatedMinutes Int     @default(15)
  completedAt      String?

  user User @relation(fields: [userId], references: [id])
  goal Goal @relation(fields: [goalId], references: [id])

  @@index([userId, date])
  @@index([goalId])
  @@map("icandoit_daily_task")
}
